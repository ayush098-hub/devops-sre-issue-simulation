# --- Specific to your current untracked files ---
# Ignore the hidden .terraform directory (contains provider binaries)
**/.terraform/

# Ignore the dependency lock file (optional, but often ignored in learning repos)
.terraform.lock.hcl

# Local state files (SENSITIVE: contains secrets in plain text)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log
.terraformrc
terraform.rc
