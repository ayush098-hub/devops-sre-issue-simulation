# --- Specific to your current untracked files ---
# Ignore the hidden .terraform directory (contains provider binaries)
**/.terraform/

# Ignore the dependency lock file (optional, but often ignored in learning repos)
.terraform.lock.hcl

# Ignore the specific tutorial folders if you don't want them in Git
tf/drift-detection/
tf/import/

# --- Standard Terraform Ignores ---
# Local state files (SENSITIVE: contains secrets in plain text)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Sensitive variable files (Never commit these!)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc
